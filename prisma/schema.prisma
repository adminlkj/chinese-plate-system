generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Branch Master Table
model Branch {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  nameEn    String?
  address   String?
  addressEn String?
  phone     String?
  email     String?
  manager   String?
  vatNumber String?
  taxRate   Decimal?
  maxDiscountPercentage Decimal?
  logo      String?
  receiptHeader String?
  receiptFooter String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts          Account[]
  transactions      Transaction[]
  journalEntries    JournalEntry[]
  tables            RestaurantTable[]
  productCategories ProductCategory[]
  products          Product[]
  stockTransactions StockTransaction[]
  stockTakes        StockTake[]
  stockTransfers    StockTransfer[] @relation("StockTransferFrom")
  stockTransfersTo  StockTransfer[] @relation("StockTransferTo")
  shifts            Shift[]
  posInvoices       POSInvoice[]
  auditLogs         AuditLog[]

  employees         Employee[]
  payrollRuns       PayrollRun[]
  salaryAdvances    SalaryAdvance[]
  allowanceTypes    AllowanceType[]
  periodLocks       PayrollPeriodLock[]
  payrollSetting    PayrollSetting?
  vatDeclarations   VatDeclaration[]
}

// Fiscal Periods
model FiscalPeriod {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journalEntries JournalEntry[]
}

// Chart of Accounts
model Account {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String
  nameEn          String?
  type            String
  parentId        String?
  branchId        String
  level           Int       @default(1)
  openingBalance  Decimal   @default("0")
  currentBalance  Decimal   @default("0")
  isActive        Boolean   @default(true)
  isSystem        Boolean   @default(false)
  isComputed      Boolean   @default(false)
  computedSource  String?
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  parent      Account?  @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children    Account[]  @relation("AccountHierarchy")
  branch      Branch?   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  journalLines JournalLine[]

  @@index([parentId])
  @@index([branchId])
  @@index([type])
  @@index([type, isActive])
}

// Customers
model Customer {
  id                 String   @id @default(cuid())
  name               String
  nameEn             String?
  type               String   @default("PLATFORM")
  discountPercentage Decimal  @default("0")
  phone              String?  @unique
  email              String?
  balance            Decimal  @default("0")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  transactions   Transaction[]
  journalEntries JournalEntry[]
  posInvoices    POSInvoice[]
}

// Suppliers
model Supplier {
  id          String   @id @default(cuid())
  name        String
  nameEn      String?
  phone       String?  @unique
  email       String?
  balance     Decimal  @default("0")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions   Transaction[]
  journalEntries  JournalEntry[]
}

// Transaction Header
model Transaction {
  id                String   @id @default(cuid())
  transactionNumber String   @unique
  type              String
  subType           String?
  date              DateTime
  description       String
  referenceCode     String?
  branchId          String
  customerId        String?
  supplierId        String?
  totalAmount       Decimal  @default("0")
  taxAmount         Decimal  @default("0")
  discountAmount    Decimal  @default("0")
  netAmount         Decimal  @default("0")
  status            String   @default("POSTED")
  paymentMethod     String?
  counterParty      String?
  invoiceNumber     String?
  parentTransactionId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer          Customer?    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  supplier          Supplier?    @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  branch            Branch?      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  parentTransaction Transaction? @relation("TransactionSettlement", fields: [parentTransactionId], references: [id])
  settlements       Transaction[] @relation("TransactionSettlement")
  journalEntries    JournalEntry[]
  posInvoices       POSInvoice[]

  @@index([date])
  @@index([branchId])
  @@index([customerId])
  @@index([supplierId])
  @@index([status])
  @@index([type])
  @@index([subType])
  @@index([date, branchId])
  @@index([type, status])
  @@index([invoiceNumber])
}

// Journal Entry
model JournalEntry {
  id              String   @id @default(cuid())
  entryNumber     String   @unique
  date            DateTime
  description     String
  type            String
  status          String   @default("DRAFT")
  reference       String?
  branchId        String
  paymentMethod   String?
  counterParty    String?
  invoiceNumber   String?
  amount          Decimal  @default("0")
  taxAmount       Decimal  @default("0")
  discountAmount  Decimal  @default("0")
  customerId      String?
  supplierId      String?
  periodId        String?
  groupId         String?
  groupRole       String?
  totalAmount     Decimal  @default("0")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactionId   String?
  period          FiscalPeriod? @relation(fields: [periodId], references: [id], onDelete: Restrict)
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  supplier        Supplier?     @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  branch          Branch?       @relation(fields: [branchId], references: [id], onDelete: Restrict)
  transaction     Transaction?  @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  lines           JournalLine[]

  @@index([status])
  @@index([date])
  @@index([branchId])
  @@index([customerId])
  @@index([supplierId])
  @@index([transactionId])
  @@index([groupId])
  @@index([invoiceNumber])
  @@index([type, status])
  @@index([date, branchId])
}

// Journal Line
model JournalLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal  @default("0")
  credit         Decimal  @default("0")
  description    String?
  createdAt      DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([accountId])
  @@index([journalEntryId])
  @@index([accountId, journalEntryId])
}

// Users
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  nameEn    String?
  password  String
  role      String   @default("VIEWER")
  allowedBranches String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permissions UserPermission[]
  shifts      Shift[]

  @@index([email])
}

model UserPermission {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  screen      String
  accessLevel String   @default("READ")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, screen])
  @@index([userId])
}

// Settings
model Setting {
  id        String @id @default(cuid())
  key       String @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Restaurant Tables
model RestaurantTable {
  id        String   @id @default(cuid())
  name      String
  branchId  String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: Restrict)
  invoices POSInvoice[]

  @@index([branchId])
}

// Product Category
model ProductCategory {
  id        String   @id @default(cuid())
  name      String
  nameEn    String?
  branchId  String
  icon      String?
  color     String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: Restrict)
  products Product[]

  @@unique([name, branchId])
  @@index([branchId])
}

// Product
model Product {
  id              String   @id @default(cuid())
  name            String
  nameEn          String?
  sku             String?  @unique
  categoryId      String
  branchId        String
  costPrice       Decimal  @default("0")
  price           Decimal  @default("0")
  unit            String   @default("قطعة")
  currentStock    Decimal  @default("0")
  minStock        Decimal  @default("0")
  maxStock        Decimal  @default("0")
  reorderQuantity Decimal  @default("0")
  isActive        Boolean  @default(true)
  sortOrder       Int      @default("0")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category ProductCategory @relation(fields: [categoryId], references: [id])
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: Restrict)

  stockTransactions StockTransaction[]
  invoiceItems POSInvoiceItem[]
  invoiceItemLinks POSInvoiceItemProduct[]
  stockTakeItems StockTakeItem[]
  transferItems StockTransferItem[]

  @@index([categoryId])
  @@index([branchId])
  @@index([isActive, branchId])
}

