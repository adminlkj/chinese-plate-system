generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== BRANCH =====================
model Branch {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  nameEn    String?
  address   String?
  addressEn String?
  phone     String?
  email     String?
  manager   String?
  vatNumber String?
  taxRate   Decimal?
  maxDiscountPercentage Decimal?
  logo      String?
  receiptHeader String?
  receiptFooter String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts          Account[]
  transactions      Transaction[]
  journalEntries    JournalEntry[]
  tables            RestaurantTable[]
  productCategories ProductCategory[]
  products          Product[]
  stockTransactions StockTransaction[]
  stockTakes        StockTake[]
  stockTransfers    StockTransfer[] @relation("StockTransferFrom")
  stockTransfersTo  StockTransfer[] @relation("StockTransferTo")
  shifts            Shift[]
  posInvoices       POSInvoice[]
  auditLogs         AuditLog[]

  employees         Employee[]
  payrollRuns       PayrollRun[]
  salaryAdvances    SalaryAdvance[]
  allowanceTypes    AllowanceType[]
  periodLocks       PayrollPeriodLock[]
  payrollSetting    PayrollSetting?
  vatDeclarations   VatDeclaration[]
}

// ===================== ACCOUNT =====================
model Account {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  nameEn          String?
  type            String
  parentId        String?
  branchId        String
  level           Int      @default(1)
  openingBalance  Decimal  @default("0")
  currentBalance  Decimal  @default("0")
  isActive        Boolean  @default(true)
  isSystem        Boolean  @default(false)
  isComputed      Boolean  @default(false)
  computedSource  String?
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parent   Account? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children Account[] @relation("AccountHierarchy")
  branch   Branch?   @relation(fields: [branchId], references: [id])
  journalLines JournalLine[]

  @@index([branchId])
}

// ===================== TRANSACTION =====================
model Transaction {
  id                String   @id @default(cuid())
  transactionNumber String   @unique
  type              String
  subType           String?
  date              DateTime
  description       String
  branchId          String
  customerId        String?
  supplierId        String?
  totalAmount       Decimal  @default("0")
  taxAmount         Decimal  @default("0")
  discountAmount    Decimal  @default("0")
  netAmount         Decimal  @default("0")
  status            String   @default("POSTED")

  customer Customer? @relation(fields: [customerId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  branch   Branch?   @relation(fields: [branchId], references: [id])

  journalEntries JournalEntry[]
  posInvoices    POSInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================== JOURNAL =====================
model JournalEntry {
  id          String   @id @default(cuid())
  entryNumber String   @unique
  date        DateTime
  description String
  type        String
  status      String   @default("DRAFT")
  branchId    String

  transactionId String?

  branch      Branch?      @relation(fields: [branchId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])
  lines       JournalLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JournalLine {
  id             String   @id @default(cuid())
  journalEntryId String
  accountId      String
  debit          Decimal  @default("0")
  credit         Decimal  @default("0")

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])
  account      Account      @relation(fields: [accountId], references: [id])

  createdAt DateTime @default(now())
}

// ===================== USER =====================
model User {
  id       String @id @default(cuid())
  email    String @unique
  name     String
  password String
  role     String @default("VIEWER")

  shifts Shift[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserPermission {
  id          String @id @default(cuid())
  userId      String
  screen      String
  accessLevel String @default("READ")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, screen])
}

// ===================== TABLE =====================
model RestaurantTable {
  id        String @id @default(cuid())
  name      String
  branchId  String
  isActive  Boolean @default(true)
  sortOrder Int @default(0)

  branch Branch? @relation(fields: [branchId], references: [id])
  invoices POSInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================== PRODUCT =====================
model Product {
  id       String @id @default(cuid())
  name     String
  sku      String? @unique
  categoryId String
  branchId String

  costPrice Decimal @default("0")
  price     Decimal @default("0")

  unit String @default("قطعة")

  currentStock Decimal @default("0")
  minStock     Decimal @default("0")
  maxStock     Decimal @default("0")

  isActive Boolean @default(true)
  sortOrder Int @default(0)

  category ProductCategory @relation(fields: [categoryId], references: [id])
  branch   Branch? @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================== CATEGORY =====================
model ProductCategory {
  id        String @id @default(cuid())
  name      String
  branchId  String
  isActive  Boolean @default(true)
  sortOrder Int @default(0)

  branch Branch? @relation(fields: [branchId], references: [id])
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===================== POS =====================
model POSInvoice {
  id            String @id @default(cuid())
  invoiceNumber String @unique
  branchId      String

  subtotal   Decimal @default("0")
  totalAmount Decimal @default("0")

  branch Branch? @relation(fields: [branchId], references: [id])
  items  POSInvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model POSInvoiceItem {
  id         String @id @default(cuid())
  invoiceId  String
  name       String
  quantity   Decimal @default("1")
  unitPrice  Decimal @default("0")
  totalPrice Decimal @default("0")

  invoice POSInvoice @relation(fields: [invoiceId], references: [id])
}

// ===================== STOCK =====================
model StockTransaction {
  id        String @id @default(cuid())
  productId String
  branchId  String
  type      String
  quantity  Decimal @default("0")

  product Product @relation(fields: [productId], references: [id])
  branch  Branch? @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
}

model StockTake {
  id       String @id @default(cuid())
  number   String @unique
  branchId String

  branch Branch? @relation(fields: [branchId], references: [id])
}

model StockTransfer {
  id           String @id @default(cuid())
  fromBranchId String
  toBranchId   String

  fromBranch Branch? @relation("StockTransferFrom", fields: [fromBranchId], references: [id])
  toBranch   Branch? @relation("StockTransferTo", fields: [toBranchId], references: [id])
}

// ===================== SHIFTS =====================
model Shift {
  id       String @id @default(cuid())
  number   String @unique
  userId   String
  branchId String

  user User? @relation(fields: [userId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
}

// ===================== CUSTOMER / SUPPLIER =====================
model Customer {
  id   String @id @default(cuid())
  name String
}

model Supplier {
  id   String @id @default(cuid())
  name String
}